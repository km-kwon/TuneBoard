TUNEBOARD_FRONTEND_ORIGIN=http://localhost:5173
TUNEBOARD_CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175

# Official YouTube Data API OAuth.
# Create a Google Cloud OAuth client for a Web application and add this redirect URI:
# http://localhost:8000/api/auth/google/callback
TUNEBOARD_GOOGLE_CLIENT_ID=
TUNEBOARD_GOOGLE_CLIENT_SECRET=
TUNEBOARD_GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback
TUNEBOARD_GOOGLE_OAUTH_TOKEN_FILE=google_oauth.json

# Optional YouTube Music auth file override. If empty, backend/browser.json or
# backend/oauth.json will be discovered automatically.
TUNEBOARD_AUTH_FILE=

# Optional ytmusicapi OAuth credentials for backend/oauth.json generated with
# `ytmusicapi oauth`. ytmusicapi recommends a "TVs and Limited Input devices"
# OAuth client for this flow.
TUNEBOARD_YTMUSIC_OAUTH_CLIENT_ID=
TUNEBOARD_YTMUSIC_OAUTH_CLIENT_SECRET=
