# Backend env — copy to backend/.env and fill in.

# Comma-separated origins allowed by CORS. Include all frontend URLs
# (production, previews, localhost) with protocol and no trailing slash.
TUNEBOARD_CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175

# Optional: path to a ytmusicapi auth headers file (browser.json or oauth.json).
# Relative paths resolve against the backend/ directory.
# Leave blank to run with unauthenticated endpoints only.
TUNEBOARD_AUTH_FILE=
